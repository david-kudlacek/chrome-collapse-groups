{
  "manifest_version": 3,
  "name": "Collapse Tab Groups",
  "version": "1.0.0",
  "description": "Collapses tab groups in Chrome on startup.",
  "permissions": ["storage", "tabGroups"],
  "icons": {
    "24": "images/icon-24.png",
    "48": "images/icon-48.png"
  },
  "action": {
    "default_popup": "popups/popup.html",
    "default_icon": "images/icon-24.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}

